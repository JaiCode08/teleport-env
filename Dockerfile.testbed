FROM ubuntu:22.04

# Avoid prompts from apt
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies and build CRIU from source
RUN apt-get update && apt-get install -y \
    build-essential \
    libprotobuf-dev \
    libprotobuf-c-dev \
    protobuf-c-compiler \
    protobuf-compiler \
    python3-protobuf \
    pkg-config \
    python3-future \
    libnl-3-dev \
    libnet-dev \
    libcap-dev \
    uuid-dev \
    git \
    iproute2 \
    python3 \
    python3-pip \
    sqlite3 \
    && pip3 install openai python-dotenv \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 -b criu-dev https://github.com/checkpoint-restore/criu.git /criu-src && \
    cd /criu-src && \
    make -j$(nproc) && \
    cp criu/criu /usr/local/bin/criu && \
    cd / && rm -rf /criu-src

# Create sandbox directories
RUN mkdir -p /sandbox

WORKDIR /sandbox
